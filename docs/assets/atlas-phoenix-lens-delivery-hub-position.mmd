flowchart TB
  subgraph lifecycle["Atlas Engineering Delivery Hub - Seven Mountains SDLC"]
    direction LR
    hub["Atlas Engineering<br/>Delivery Hub"]
    early["M1-M2<br/>Planning + Estimation"]
    m3["M3 Discovery<br/>understand the current estate"]
    downstream["M4-M7<br/>Build to Maintenance"]
    hub --> early --> m3 --> downstream
  end

  m3 --> lens["Atlas Phoenix Lens<br/>Discovery capability"]
  lens --> map["Program Flow Map<br/>bounded scope and navigation"]
  map --> core["Evidence Core<br/>RPG / CL / DDS analysis"]
  core --> dify["Dify Knowledge Activation<br/>retrieval, Q&A, BRD draft"]
  dify --> sme["SME Governance<br/>review, decision, write-back"]
  sme --> package["Reviewed Modernization<br/>Knowledge Package"]
  package -. trusted input .-> downstream

  classDef hub fill:#071933,stroke:#20c8ff,color:#ffffff,stroke-width:3px
  classDef stage fill:#10243f,stroke:#7aa7d9,color:#ffffff
  classDef discovery fill:#153a2f,stroke:#4bd39c,color:#ffffff,stroke-width:3px
  classDef component fill:#182238,stroke:#20c8ff,color:#ffffff
  classDef governance fill:#4b1d16,stroke:#f4a83a,color:#ffffff
  classDef output fill:#263852,stroke:#7aa7d9,color:#ffffff

  class hub hub
  class early,downstream stage
  class m3,lens discovery
  class map,core,dify component
  class sme governance
  class package output
