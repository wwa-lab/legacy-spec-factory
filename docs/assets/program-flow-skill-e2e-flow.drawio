          <mxGeometry x="70" y="210" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="phase1" value="Phase 1&#xa;Build Batch Queue&#xa;Inventory preflight&#xa;Create flow-program-list.csv&#xa;Create prompt-queue/*.md&#xa;Create batch status/manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#9333ea;fontColor=#581c87;fontSize=15;fontStyle=1;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="210" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="phase2" value="Phase 2&#xa;Analyze Programs&#xa;One fresh Copilot Chat per program&#xa;Write current-run program artifacts&#xa;Update program-list-status.csv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontColor=#7c2d12;fontSize=15;fontStyle=1;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="750" y="210" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="phase3" value="Phase 3&#xa;Assemble Review&#xa;Read batch folder&#xa;Derive output_dir automatically&#xa;Build program-set review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=15;fontStyle=1;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1120" y="210" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="phase4" value="Phase 4&#xa;Validate + Review&#xa;Run validator&#xa;SME reviews four core sections&#xa;PR / merge records durable history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontColor=#1e1b4b;fontSize=15;fontStyle=1;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1490" y="210" width="260" height="170" as="geometry" />
        </mxCell>
        <mxCell id="guardrail1" value="No cross-run reuse&#xa;Do not use remote main, old branch artifacts, or another analyst's prior run as completion evidence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#334155;fontSize=14;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="500" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="guardrail2" value="Same-run repeat only&#xa;If a program repeats inside this run, reuse the artifact produced earlier in the same batch." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontColor=#14532d;fontSize=14;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="500" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="guardrail3" value="Self-contained SME review&#xa;Calculation Logic, Validation Logic, Exception Handling, and Message Inventory live in program-set-sme-core-review.md." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontColor=#7c2d12;fontSize=14;spacing=12;" vertex="1" parent="1">
